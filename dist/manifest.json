{
  "manifest_version": 2,
  "name": "Mage",
  "version": "1.0",
  "description": "Age encryption extension for Firefox",
  "permissions": ["storage", "clipboardWrite", "tabs"],
  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "Aged"
  },
  "background": {
    "scripts": ["background.js"]
  }
}