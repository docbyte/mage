{
  "manifest_version": 3,
  "name": "Mage",
  "version": "1.0",
  "description": "Age encryption extension for Firefox",
  "permissions": ["storage", "clipboardWrite", "tabs"],
  "action": {
    "default_icon": "icon.png",
    "default_title": "Aged"
  },
  "background": {
    "service_worker": "background.js"
    ,"scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mage-extension@example.com",
      "data_collection_permissions": {
        "required": ["none"],
        "telemetry": "not_collected",
        "interactive_data": "not_collected"
      }
    }
  }

}